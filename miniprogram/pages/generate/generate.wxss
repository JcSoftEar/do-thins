.section {
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.input-field {
  font-size: 32rpx;
  color: #333;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.textarea-field {
  font-size: 32rpx;
  color: #333;
  min-height: 120rpx;
  padding: 10rpx 0;
}

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.icon-item {
  width: 90rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}

.icon-item.selected {
  background: #E8F0FA;
  transform: scale(1.1);
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  transition: all 0.2s;
}

.color-item.selected {
  transform: scale(1.2);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.days-item {
  padding: 16rpx 30rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}

.days-item.selected {
  background: #4A90E2;
  color: #fff;
}

.preview-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.preview-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.preview-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.preview-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.preview-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.preview-progress {
  display: flex;
  align-items: center;
}

.preview-progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.preview-progress-fill {
  height: 100%;
  border-radius: 6rpx;
}

.preview-progress-text {
  font-size: 24rpx;
  color: #999;
}

.save-btn-container {
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: center;
}
