.calendar-section {
  padding: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.calendar-nav {
  display: flex;
  gap: 20rpx;
}

.nav-btn {
  font-size: 32rpx;
  color: #4A90E2;
  padding: 10rpx 20rpx;
}

.calendar-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.calendar-weekdays text {
  width: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.calendar-day {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  margin: 8rpx 0;
}

.calendar-day.today {
  color: #4A90E2;
  font-weight: 600;
}

.calendar-day.checked {
  background: #4A90E2;
  color: #fff;
  border-radius: 50%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 30rpx 0 20rpx;
  padding: 0 20rpx;
}

.checkin-list {
  padding: 0 20rpx;
}

.checkin-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.checkin-card.completed {
  opacity: 0.6;
}

.checkin-header {
  display: flex;
  align-items: center;
  flex: 1;
}

.checkin-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.checkin-info {
  display: flex;
  flex-direction: column;
}

.checkin-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.checkin-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.checkin-btn {
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  background: #4A90E2;
  color: #fff;
}

.checkin-btn.btn-disabled {
  background: #ccc;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.record-list {
  padding: 0 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-bottom: 15rpx;
}

.record-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
