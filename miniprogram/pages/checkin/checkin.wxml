<view class="container">
  <!-- 打卡日历 -->
  <view class="calendar-section card">
    <view class="calendar-header">
      <text class="calendar-title">{{currentMonth}}</text>
      <view class="calendar-nav">
        <text class="nav-btn" bindtap="prevMonth">&lt;</text>
        <text class="nav-btn" bindtap="nextMonth">&gt;</text>
      </view>
    </view>
    <view class="calendar-weekdays">
      <text wx:for="{{weekdays}}" wx:key="this">{{item}}</text>
    </view>
    <view class="calendar-days">
      <view 
        class="calendar-day {{item.isToday ? 'today' : ''}} {{item.isChecked ? 'checked' : ''}}" 
        wx:for="{{calendarDays}}" 
        wx:key="index"
      >
        {{item.day}}
      </view>
    </view>
  </view>

  <!-- 今日打卡列表 -->
  <view class="section-title">今日待打卡</view>
  <view class="checkin-list">
    <view 
      class="checkin-card card {{checkedInIds.includes(item.id) ? 'completed' : ''}}" 
      wx:for="{{todayHabits}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="doCheckin"
    >
      <view class="checkin-header">
        <view class="checkin-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
        <view class="checkin-info">
          <text class="checkin-name">{{item.name}}</text>
          <text class="checkin-desc">{{item.description}}</text>
        </view>
      </view>
      <view class="checkin-action">
        <view class="checkin-btn {{checkedInIds.includes(item.id) ? 'btn-disabled' : ''}}">
          {{checkedInIds.includes(item.id) ? '已打卡' : '打卡'}}
        </view>
      </view>
    </view>
    
    <view class="empty-tip" wx:if="{{todayHabits.length === 0}}">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">今日已全部打卡完成！</text>
    </view>
  </view>

  <!-- 打卡记录 -->
  <view class="section-title">最近打卡</view>
  <view class="record-list">
    <view class="record-item card" wx:for="{{recentRecords}}" wx:key="id">
      <view class="record-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
      <view class="record-info">
        <text class="record-name">{{item.name}}</text>
        <text class="record-time">{{item.checkinTime}}</text>
      </view>
    </view>
  </view>
</view>
