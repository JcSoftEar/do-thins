<view class="container" wx:if="{{habit}}">
  <!-- 习惯信息卡片 -->
  <view class="habit-header card">
    <view class="habit-icon" style="background-color: {{habit.color}}">{{habit.icon}}</view>
    <view class="habit-info">
      <text class="habit-name">{{habit.name}}</text>
      <text class="habit-desc">{{habit.description}}</text>
    </view>
    <view class="share-btn" bindtap="shareToFriend">分享</view>
  </view>

  <!-- 统计数据 -->
  <view class="statistics-section">
    <view class="stat-card card">
      <text class="stat-value">{{statistics.totalDays}}</text>
      <text class="stat-label">已完成天数</text>
    </view>
    <view class="stat-card card">
      <text class="stat-value">{{statistics.completionRate}}%</text>
      <text class="stat-label">完成率</text>
    </view>
    <view class="stat-card card">
      <text class="stat-value">{{statistics.longestStreak}}</text>
      <text class="stat-label">最长连续</text>
    </view>
  </view>

  <!-- 进度展示 -->
  <view class="progress-section card">
    <view class="progress-header">
      <text class="progress-title">目标进度</text>
      <text class="progress-days">{{habit.completedDays}}/{{habit.targetDays}}天</text>
    </view>
    <view class="progress-bar">
      <view 
        class="progress-fill" 
        style="width: {{habit.completedDays / habit.targetDays * 100}}%; background-color: {{habit.color}}"
      ></view>
    </view>
    <view class="progress-tips">
      <text>还剩 {{habit.targetDays - habit.completedDays}} 天完成目标</text>
    </view>
  </view>

  <!-- 打卡日历 -->
  <view class="calendar-section card">
    <view class="section-title">打卡记录</view>
    <view class="history-calendar">
      <view 
        class="history-day {{item.isCompleted ? 'completed' : ''}}" 
        wx:for="{{checkinHistory}}" 
        wx:key="index"
      >
        <text class="day-number">{{item.date}}</text>
        <view class="day-status {{item.isCompleted ? 'checked' : ''}}">
          {{item.isCompleted ? '✓' : '·'}}
        </view>
        <text class="week-day">{{item.weekDay}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="btn-primary" bindtap="goToCheckin">立即打卡</button>
    <button class="btn-secondary" bindtap="editHabit">编辑习惯</button>
  </view>
</view>
