/*app.wxss*/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2, #67B1E7);
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #ffffff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

.text-primary {
  color: #4A90E2;
}

.text-gray {
  color: #999999;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}
