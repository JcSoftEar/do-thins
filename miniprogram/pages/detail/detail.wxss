.habit-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
}

.habit-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
}

.habit-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.habit-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.habit-desc {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
}

.share-btn {
  font-size: 28rpx;
  color: #4A90E2;
  padding: 12rpx 24rpx;
  border: 1rpx solid #4A90E2;
  border-radius: 24rpx;
}

.statistics-section {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  margin: 0 10rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #4A90E2;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.progress-section {
  padding: 30rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 28rpx;
  color: #666;
}

.progress-days {
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 600;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-tips {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.calendar-section {
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.history-calendar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-day {
  width: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.day-number {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.day-status {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.day-status.checked {
  background: #4A90E2;
  color: #fff;
}

.week-day {
  font-size: 20rpx;
  color: #999;
}

.action-section {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-section .btn-secondary {
  background: #f5f5f5;
  color: #666;
  border: none;
}
